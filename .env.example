# ============================================================
# Mission Control — Environment Configuration
# Run ./setup.sh to generate .env with secure random secrets,
# or copy this file to .env and fill in values yourself.
# ============================================================

# ── Core (required — setup.sh generates these) ──────────────
# PostgreSQL password
DB_PASSWORD=change_me_strong_password_here

# Redis password
REDIS_PASSWORD=change_me_generate_with_openssl_rand_hex_16

# JWT secret for user login sessions (openssl rand -hex 32)
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# Legacy single-token auth fallback (empty = disabled; prefer user login)
LOCAL_AUTH_TOKEN=

# Fernet key for encrypted API keys in the DB
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# Optional service groups: comma-separated compose profiles.
# voice   = LiveKit + voice worker (needs LIVEKIT_*/XAI keys)
# browser = Playwright visual-verify sidecars for agents
# Empty = lean core stack (db, redis, backend, frontend, caddy, qdrant).
COMPOSE_PROFILES=

# Set to 1 to disable automatic DB migrations on backend start
# (for deployments that manage migrations manually).
MC_SKIP_MIGRATIONS=0

# ── Host integration (required — setup.sh fills these) ──────
# Your numeric user id (`id -u`) — used for the host tmux socket path.
HOST_UID=1000
# Absolute path of this repo checkout — used for cross-image runtime switches.
MC_REPO_PATH=

# ── Identity (optional) ──────────────────────────────────────
# How your agents address you (rendered into SOUL.md/USER.md)
OPERATOR_NAME=Operator
# Brand/site name used in generated newsletter copy
NEWSLETTER_BRAND=AI Weekly
# macOS host login for host-agent lifecycle (empty = derived from home dir)
HOST_SSH_USER=

# Wordmark/brand in the UI, split main.accent at the last dot
# (default: Mission.Control). Baked at frontend BUILD time.
NEXT_PUBLIC_BRAND=

# ── URLs / network (optional) ────────────────────────────────
# Externally reachable base URL (used in notification links)
MC_BASE_URL=http://localhost
# Interface Caddy (ports 80/443) binds to. Default 127.0.0.1 = this machine
# only (secure default — nobody on your LAN can reach MC or claim the first
# admin account). Set to 0.0.0.0 to reach MC from other devices, e.g. your
# phone via Tailscale — see README "Access from your phone".
MC_BIND_ADDRESS=127.0.0.1
# Externally reachable host (VPN/LAN IP or DNS) for CORS + phone links
PUBLIC_HOST=
# Comma-separated list of additional allowed CORS origins
EXTRA_CORS_ORIGINS=

# ── GitHub (optional — agent git workflow: repos, PRs, merges) ─
GH_TOKEN=
# GitHub user/org under which MC creates project repos
GITHUB_OWNER=
# Repo-name prefixes the visibility monitor keeps private (comma-separated)
MC_OWNED_REPO_PREFIXES=mc-,mc-task-,t2-

# ── Discord (optional — notifications + per-agent channels) ──
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CATEGORY_ID=
# Webhook for ops/error notifications
DISCORD_WEBHOOK_OPS=

# ── Telegram (optional — approval buttons + report delivery) ─
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPORTS_BOT_TOKEN=
TELEGRAM_REPORTS_CHAT_ID=

# ── Voice agent (optional — LiveKit + xAI realtime) ──────────
# LiveKit server key list, YAML mapping format WITH the space: "key: secret"
LIVEKIT_KEYS=
# Same pair split for backend token signing
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# WS URL the browser client connects to (empty = derived from request origin)
LIVEKIT_PUBLIC_URL=
# RTC candidate IP LiveKit advertises (your LAN/VPN IP; 127.0.0.1 = local only)
LIVEKIT_NODE_IP=
# xAI API key for the realtime voice model
XAI_API_KEY=
# MC agent token for the voice worker (create the agent, then paste its token)
JARVIS_AGENT_TOKEN=

# ── Remote LLM runtime host via SSH (optional) ───────────────
# If you run LM Studio / vLLM / Unsloth on a separate machine, MC connects
# via SSH for lifecycle commands (load/unload, docker start/stop). Requires
# the ~/.ssh mount from docker-compose.override.example.yml.
DGX_SSH_HOST=
DGX_SSH_USER=
DGX_SSH_KEY_PATH=/home/mcuser/.ssh/id_rsa

# ── Runtime registry ─────────────────────────────────────────
# On first start MC seeds backend/config/runtimes.json into the `runtimes`
# DB table. Edit that JSON to reflect YOUR hardware (endpoint URLs, model
# identifiers). After the first seed, manage runtimes via the UI (/runtimes).

# ── Feature flags (optional, defaults shown) ─────────────────
# Kill-switch: false = legacy single-session dispatch (rollback, ADR-002)
USE_SUBAGENT_DISPATCH=true
ENABLE_DISPATCH_GATING=false
STRUCTURED_INTAKE_ENABLED=false
ENABLE_PROMOTE_ORCHESTRATOR=false

# Eigene GPU-Box (optional): OpenAI-kompatible Endpoints fuer Embedding + LLM
# SPARK_EMBEDDING_URL=http://<gpu-host>:1234/v1/embeddings
# SPARK_LLM_URL=http://<gpu-host>:8000/v1
