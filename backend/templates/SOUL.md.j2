{
  "question_type": "spawn_approval",
  "context": "<why a new agent is needed — which gap in the team>",
  "payload": {
    "name": "<descriptive name>",
    "role": "<developer|researcher|writer|...>",
    "scopes": ["<minimum required — least privilege>"],
    "skill_filter": ["<only allowed skills>"],
    "cli_plugins": ["<matching plugins>"],
    "soul_md": "<concise, role-specific SOUL>",
