# Agent-spezifische Konfiguration fuer {{ agent_name }}
# Wird von worker.sh NACH dem shared env-File geladen (ueberschreibt shared Werte)

# Mission Control Auth Token (einzigartig pro Agent)
MC_AGENT_TOKEN={{ mc_agent_token }}

# MC API Base URL — Host-CLI-Bridge-Agents erreichen Caddy auf localhost
# (Docker-V2-Agents setzen MC_API_URL separat via docker-compose.agents.yml)
MC_API_URL=http://localhost

{% if not is_claude_bin %}
# Agent-eigenes Plugin-Verzeichnis (nur fuer openclaude)
CLAUDE_CONFIG_DIR={{ claude_config_dir }}
{% endif %}
