# Agent-specific configuration for {{ agent_name }}
# Loaded by worker.sh AFTER the shared env file (overrides shared values)

# Mission Control auth token (unique per agent)
MC_AGENT_TOKEN={{ mc_agent_token }}

# MC API base URL — host CLI-bridge agents reach Caddy on localhost
# (Docker V2 agents set MC_API_URL separately via docker-compose.agents.yml)
MC_API_URL=http://localhost

{% if not is_claude_bin %}
# Agent-specific plugin directory (openclaude only)
CLAUDE_CONFIG_DIR={{ claude_config_dir }}
{% endif %}
