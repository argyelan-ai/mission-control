<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mc.poll-health</string>

    <!-- Static example plist — replace /Users/YOUR_USER with your actual home dir before installing -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/YOUR_USER/.mc/poll-health-check.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/YOUR_USER/.mc/poll-health-launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USER/.mc/poll-health-launchd.log</string>
</dict>
</plist>
